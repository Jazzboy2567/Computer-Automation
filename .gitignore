# --- Pilot-specific (NEVER commit these) ---
# Persistent browser profile holds YOUR logged-in cookies/session. Keep it local.
profiles/
# Run artifacts: screenshots, extracted text, generated reports.
runs/
# Per-goal ML workspaces (data snapshots, model artifacts, results).
ml_workspaces/
# Any secrets / API keys.
.env
.env.*
secrets.json
*.secret

# --- Python ---
# uv writes this when used in project mode; we use the pip-style `uv pip install`
# flow, so it isn't consumed — ignore it rather than ship a stale lockfile.
uv.lock
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Playwright ---
test-results/
playwright-report/

# --- Editors / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
